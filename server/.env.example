# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL from: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project.supabase.co

# Service Role key — NEVER expose to the client/frontend.
# Found at: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anon key — used by requireAuth middleware to verify JWTs.
# Found at: Supabase Dashboard → Settings → API → anon / public key
SUPABASE_ANON_KEY=eyJ...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4242

# Your deployed frontend URL (used for Stripe redirect URLs and CORS)
CLIENT_URL=http://localhost:3000
