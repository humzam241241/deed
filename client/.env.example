# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL from: Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Anon/public key — safe to expose in the browser
# Found at: Supabase Dashboard → Settings → API → anon / public key
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Stripe ───────────────────────────────────────────────────────────────────
# Publishable key — safe to expose in the browser
# Found at: Stripe Dashboard → Developers → API Keys → Publishable key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Backend API ───────────────────────────────────────────────────────────────
# URL of your Express server
VITE_API_URL=http://localhost:4242

# ── Optional (already used by the app) ───────────────────────────────────────
VITE_CALENDLY_URL=
VITE_GOOGLE_CALENDAR_URL=
